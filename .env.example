# Neon: Dashboard → Connection string → copia la URI (incluye ?sslmode=require)
DATABASE_URL=postgresql://usuario:contraseña@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# Vercel Blob — comprobantes en producción (Storage en el proyecto Vercel; token de lectura/escritura)
# Sin esto, adjuntar imagen/PDF al registrar pago falla en Vercel (el disco del despliegue es solo lectura).
# BLOB_READ_WRITE_TOKEN=

ADMIN_PASSWORD=cambia-esto
SESSION_SECRET=una-cadena-larga-y-aleatoria

# Mercado Pago (Checkout Pro): credenciales → https://www.mercadopago.com.pe/developers/panel/app
# Usa el Access Token de prueba (TEST-...) o producción. Debe coincidir con la moneda/cuenta (PEN).
MERCADOPAGO_ACCESS_TOKEN=
# URL pública de tu sitio (sin barra final). Necesaria para volver del checkout y para webhooks.
PUBLIC_URL=http://localhost:3000

# Monto en PEN para todos los pagos del formulario público (sin campo de monto en pantalla).
DEFAULT_PAYMENT_MONTO=1

# Vouchers — API «Futbol Bot». POST /admin/vouchers/generate requiere cabecera X-Admin-Token (Swagger / Authorize).
VOUCHER_ADMIN_TOKEN=
# En Vercel/producción: URL pública del API (nunca localhost). Una de estas dos:
# VOUCHER_GENERATE_URL=https://tu-api-publica.com/admin/vouchers/generate
# VOUCHER_SERVICE_URL=https://tu-api-publica.com
# Local (opcional; por defecto http://localhost:8000/...):
# VOUCHER_GENERATE_URL=http://127.0.0.1:8000/admin/vouchers/generate
# VOUCHER_SERVICE_URL=http://127.0.0.1:8000
